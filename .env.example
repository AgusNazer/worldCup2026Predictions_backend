# Ejemplo de variables de entorno para backend
# Copia este archivo a `.env` y completa con tus credenciales reales

# Base de datos PostgreSQL
# Generar credenciales seguras y cambiar en docker-compose.yml también
DATABASE_URL=postgresql://worldcup_user:your-strong-password-here@db:5432/worldcup

# JWT Secret key (REQUERIDO - generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
# Esto es crítico para la seguridad de autenticación
SECRET_KEY=your-secure-random-key-here-minimum-32-chars

# CORS Origins (comma-separated, sin espacios)
CORS_ORIGINS=http://localhost:3000

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60